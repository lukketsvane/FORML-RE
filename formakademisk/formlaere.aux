\citation{fieldslevin2022}
\citation{wright1932,lande1979,arnold2001,wagner2005,mcghee2007,polly2016}
\citation{contrerasfigueroa2023}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces \texorpdfstring {\xpg@aux {variant=nynorsk}{norwegian}}{}\ignorespaces Grensetilfelle-plott. Den vertikale aksen måler grammatikkens rikdom (triviell til rik); den horisontale måler tilpassingslandskapets struktur (flatt til strukturert). Formgrammatikken \citep  {stinygips1972} okkuperer øvre venstre: rik grammatikk, flatt landskap. C-K-teorien \citep  {hatchuelweil2003} okkuperer nedre høgre: triviell grammatikk, strukturert landskap (gjennom partisjonen). Formlære med full kjerne-likning okkuperer øvre høgre, der begge er aktive samstundes. Nedre venstre er utelukka: verken grammatikk eller landskap gjev inga formell formvitskap.}}{6}{}\protected@file@percent }
\newlabel{fig:grensetilfelle}{{11}{6}{Det nye laget}{figure.11}{}}
