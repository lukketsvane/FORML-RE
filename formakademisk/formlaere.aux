\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \texorpdfstring {\xpg@aux {variant=nynorsk}{norwegian}}{}\ignorespaces Boltzmann-fordeling $P(F) \propto \exp (-\beta \hat  {\mathcal  {L}}(F))$ over eit to-dimensjonalt formrom, ved tre verdiar av den inverse temperaturen $\beta $. Låg $\beta $ (varmt) gjev brei spreiing over fleire haugar; høg $\beta $ (kaldt) konsentrerer sannsynet rundt dei globale toppane.}}{4}{}\protected@file@percent }
\newlabel{fig:boltzmann}{{8}{4}{Stasjonær fordeling og MaxEnt-konsistens}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \texorpdfstring {\xpg@aux {variant=nynorsk}{norwegian}}{}\ignorespaces Tre kandidatar til stasjonær fordeling. Boltzmann (venstre) har stramme halar og ein modus; Pareto (midten) har tunge halar og konsentrerer mest masse nær null; lognormal (høgre) er høgreskeiv med moderate halar.}}{4}{}\protected@file@percent }
\newlabel{fig:alternativ}{{9}{4}{Stasjonær fordeling og MaxEnt-konsistens}{figure.9}{}}
